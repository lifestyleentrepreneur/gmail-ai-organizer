# ── Clé API Anthropic (Claude) — OBLIGATOIRE ────────────────────────────────
# Obtenir la clé sur https://console.anthropic.com
# Il faut avoir au moins 5 $ de crédit sur le compte pour que l'API fonctionne.
# La clé commence par sk-ant-api03-...
ANTHROPIC_API_KEY=sk-ant-api03-REMPLACER_PAR_TA_VRAIE_CLE

# ── Ton adresse email Gmail ─────────────────────────────────────────────────
# Utilisée pour détecter les conversations où tu n'as pas encore répondu.
# Si cette variable n'est pas remplie, la fonction "étoiler les emails sans réponse"
# sera désactivée (le reste du script fonctionnera normalement).
USER_EMAIL=ton.email@gmail.com
